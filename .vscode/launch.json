{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Current File (clean output)",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "internalConsole",
      "internalConsoleOptions": "openOnSessionStart",
      "justMyCode": true
    },
    {
      "name": "Python: Current File (terminal)",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
